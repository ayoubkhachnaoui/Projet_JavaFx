<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import org.kordamp.ikonli.javafx.FontIcon?>
<?import javafx.geometry.Insets?>

<StackPane xmlns="http://javafx.com/javafx"
           xmlns:fx="http://javafx.com/fxml"
           fx:controller="org.example.projet_java_fx.controllers.LoginController"
           prefHeight="600.0" prefWidth="800.0"
           styleClass="root-pane">

    <VBox alignment="CENTER" spacing="20" maxWidth="400" maxHeight="500" styleClass="card">
        <padding>
            <Insets top="40" right="40" bottom="40" left="40"/>
        </padding>

        <FontIcon iconLiteral="fas-user-circle" iconSize="80" styleClass="icon-graphic"/>
        
        <VBox alignment="CENTER" spacing="5">
            <Label text="Bienvenue" styleClass="title-text"/>
            <Label text="Connectez-vous pour continuer" styleClass="subtitle-text"/>
        </VBox>

        <VBox spacing="15" alignment="CENTER_LEFT">
            <VBox spacing="5">
                <Label text="Nom d'utilisateur"/>
                <TextField fx:id="usernameField" promptText="Entrez votre nom d'utilisateur"/>
            </VBox>

            <VBox spacing="5">
                <Label text="Mot de passe"/>
                <PasswordField fx:id="passwordField" promptText="Entrez votre mot de passe"/>
            </VBox>
        </VBox>

        <Button fx:id="loginButton" text="Se connecter" onAction="#handleLogin" 
                maxWidth="Infinity" styleClass="button-primary"/>
        
        <Label fx:id="errorLabel" textFill="red" wrapText="true" alignment="CENTER"/>
    </VBox>

    <HBox alignment="BOTTOM_RIGHT" pickOnBounds="false">
        <padding>
            <Insets bottom="20" right="20"/>
        </padding>
        <Button onAction="#toggleTheme" styleClass="button">
            <graphic>
                <FontIcon iconLiteral="fas-adjust" iconSize="20"/>
            </graphic>
        </Button>
    </HBox>

</StackPane>
